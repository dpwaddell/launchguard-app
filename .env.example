# App
APP_URL=https://launchguard.sample-guard.com
SHOPIFY_APP_URL=https://launchguard.sample-guard.com

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_customers,read_orders
SHOPIFY_APP_HANDLE=launchguard-2

# Session
SESSION_COOKIE_SECRET=change-me-to-32-random-chars-minimum

# Database
DATABASE_URL=postgresql://launchguard:changeme@postgres:5432/launchguard
POSTGRES_DB=launchguard
POSTGRES_USER=launchguard
POSTGRES_PASSWORD=changeme

# Email (optional — store-only mode if not configured)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
OWNER_NOTIFICATION_EMAIL=

# CORS
CORS_ORIGINS=https://launchguard.sample-guard.com

# Proxy
TRUST_PROXY=1
